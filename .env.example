ENV=dev

# Server
SERVER_ADDRESS=:8080
SERVER_READ_TIMEOUT=5s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=60s
SERVER_BODY_LIMIT_BYTES=1048576
SERVER_SHUTDOWN_TIMEOUT=10s

# Database (Supabase Postgres)
DB_DRIVER=postgres
DB_DSN=postgres://USER:PASSWORD@HOST:5432/DB?sslmode=require

# Redis
REDIS_ENABLED=true
REDIS_ADDR=localhost:6379

# Rate limiting
RATE_LIMIT_DEFAULT_RPS=10
RATE_LIMIT_DEFAULT_BURST=20
RATE_LIMIT_USE_REDIS=false
RATE_LIMIT_REDIS_PREFIX=rate_limit

# CORS
CORS_ENABLED=false
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID
CORS_EXPOSE_HEADERS=X-RateLimit-Limit,X-RateLimit-Remaining,X-RateLimit-Reset
CORS_MAX_AGE_SECONDS=600

# Auth
AUTH_ENABLED=false
AUTH_API_KEY=

# Metrics
METRICS_ENABLED=true
METRICS_PATH=/metrics
